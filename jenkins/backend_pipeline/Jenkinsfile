pipeline {
    agent any
    tools {
        jdk 'jdk-17'
        gradle 'gradle-9.2.0'
    }

    environment {
        REGISTRY = "172.16.X.52"
        PROJECT  = "demo"
        IMAGE    = "${REGISTRY}/${PROJECT}/app:${BUILD_NUMBER}"

        GIT_REPO = "git@172.16.X.51:cve-labhub/cve-labhub-backend.git"
        GIT_BRANCH = "dev"

        INFRA_REPO = "git@172.16.X.51:cve-labhub/cve-labhub-infra.git"
        INFRA_BRANCH = "main"
    }

    stages {

        stage('Clone Repositories') {
            steps {
                echo "🔹 Backend, Infra 저장소 클론 중..."
                dir('backend') {
                    git branch: "${GIT_BRANCH}",
                        credentialsId: 'git',
                        url: "${GIT_REPO}"
                }
                dir('infra') {
                    git branch: "${INFRA_BRANCH}",
                        credentialsId: 'git',
                        url: "${INFRA_REPO}"
                }
            }
        }

        stage('Build Artifact') {
            steps {
                echo " Gradle 빌드 실행..."
                dir('backend') {
                    sh 'gradle clean build -x test --info'
                }
            }
        }
        

        stage('Docker Build') {
            steps {
                echo " Docker 이미지 빌드 중..."
                sh "docker build -t ${IMAGE} -f infra/manifest/backend/Dockerfile backend"
            }
        }

        stage('Docker Login to Harbor') {
            steps {
                echo " Harbor 레지스트리 로그인..."
                withCredentials([
                    usernamePassword(credentialsId: 'harbor-credential', usernameVariable: 'HUSER', passwordVariable: 'HPASS')
                ]) {
                    sh '''
                        echo "$HPASS" | docker login $REGISTRY -u "$HUSER" --password-stdin
                    '''
                }
            }
        }

        stage('Push Unsigned Image') {
            steps {
                echo " Harbor로 이미지 push..."
                sh "docker push ${IMAGE}"
            }
        }

        stage('Sign Image with Cosign') {
            steps {
                echo "🔏 cosign 서명 중..."
                withCredentials([
                    file(credentialsId: 'cosign-key', variable: 'COSIGN_KEY'),
                    string(credentialsId: 'cosign-pass', variable: 'COSIGN_PASS')
                ]) {
                    sh '''
                        export COSIGN_PASSWORD="$COSIGN_PASS"
                        cosign sign --yes --key "$COSIGN_KEY" ${IMAGE}
                    '''
                }
            }
        }

        stage('Cleanup') {
            steps {
                echo " 로컬 이미지 정리..."
                sh 'docker rmi ${IMAGE} || true'
            }
        }

        stage('Update YAML Image Tag and Push') {
            steps {
                echo " YAML 내 Harbor 이미지 버전 업데이트 및 커밋 중..."
                dir('infra') {
                    sshagent(credentials: ['git']) {
                        sh '''
                            IMAGE_PATH="${REGISTRY}/${PROJECT}/app"
                            NEW_TAG="${BUILD_NUMBER}"

                            echo "🔹 YAML 파일의 '${IMAGE_PATH}:<old>' → '${IMAGE_PATH}:${NEW_TAG}' 로 변경합니다."

                            grep -rl "${IMAGE_PATH}:" . | while read -r file; do
                                echo "  ▶ ${file} 수정 중..."
                                sed -i "s|${IMAGE_PATH}:.*|${IMAGE_PATH}:${NEW_TAG}|g" "$file"
                            done

                            git add .
                            git commit -m "ci: Update image to ${IMAGE_PATH}:${NEW_TAG}" || echo "No changes to commit"
                            git push origin ${INFRA_BRANCH}
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo " 성공적으로 Harbor에 서명된 이미지 업로드 및 YAML 버전 업데이트 완료!"
        }
        failure {
            echo " 빌드 실패! 로그를 확인하세요."
        }
    }
}
